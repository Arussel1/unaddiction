{
  "name": "socialfine",
  "version": "1.2.7",
  "description": "Curb social media addiction with $1 CAD fines",
  "private": true,
  "scripts": {
    "test": "jest --verbose",
    "build": "zip -r socialfine.xpi . -x \"node_modules/*\" \"tests/*\" \".git/*\" \"package*\" \"jest*\" \"README.md\" \"socialfine.xpi\" \"source.zip\" \"bump-version.js\"",
    "build-patch": "npm run bump:patch && npm run build",
    "build-minor": "npm run bump:minor && npm run build",
    "build-major": "npm run bump:major && npm run build",
    "bump:major": "node bump-version.js major",
    "bump:minor": "node bump-version.js minor",
    "bump:patch": "node bump-version.js patch",
    "package-source": "zip -r source.zip . -x \"node_modules/*\" \".git/*\" \"socialfine.xpi\" \"source.zip\""
  },
  "devDependencies": {
    "jest": "^29.0.0"
  }
}
