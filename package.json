    "setup-auth": "node config-gen.js",
    "build": "zip -r socialfine.xpi . -x \"node_modules/*\" \"tests/*\" \".git/*\" \".env*\" \"package*\" \"jest*\" \"config-gen.js\" \"README.md\" \"socialfine.xpi\" \"source.zip\"",
